# Production example env
# Copy to .env.production and replace placeholders.

# Use Simple Analytics in production
VITE_ANALYTICS_PROVIDER=simple

# Optional if switching provider to ga4
VITE_GA_MEASUREMENT_ID=

# Restrict analytics to production hostnames
VITE_ANALYTICS_HOSTS=egonzalezcortes.com,www.egonzalezcortes.com
