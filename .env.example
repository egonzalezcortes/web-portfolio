# Generic example env file
# Copy values into environment-specific files as needed.

# Analytics provider: none | simple | ga4
NUXT_PUBLIC_ANALYTICS_PROVIDER=none

# GA4 Measurement ID (format: G-XXXXXXXXXX), required only when provider=ga4
NUXT_PUBLIC_GA_MEASUREMENT_ID=

# Comma-separated hostnames where analytics is allowed
NUXT_PUBLIC_ANALYTICS_HOSTS=egonzalezcortes.com,www.egonzalezcortes.com
