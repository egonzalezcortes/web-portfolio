# Staging example env
# Copy to .env.staging

# Disable analytics in staging
NUXT_PUBLIC_ANALYTICS_PROVIDER=none

# Keep empty when provider is none/simple
NUXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional: include only production hosts so staging never sends events
NUXT_PUBLIC_ANALYTICS_HOSTS=egonzalezcortes.com,www.egonzalezcortes.com
