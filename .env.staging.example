# Staging example env
# Copy to .env.staging

# Disable analytics in staging
VITE_ANALYTICS_PROVIDER=none

# Keep empty when provider is none/simple
VITE_GA_MEASUREMENT_ID=

# Optional: include only production hosts so staging never sends events
VITE_ANALYTICS_HOSTS=egonzalezcortes.com,www.egonzalezcortes.com
